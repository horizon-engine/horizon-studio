{
	"name": "@horizonstudio/editor",
	"description": "A visual node-based editor interface built with SvelteKit",
	"version": "0.0.1",
	"license": "MIT",
	"author": "Mateo Barbey",
	"type": "module",
	"files": [
		"dist",
		"!dist/**/*.d.ts.map"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/horizon-engine/horizon-studio"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"visual-editor",
		"node-editor",
		"graph-editor"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && svelte-package && pnpm run build:css && publint",
		"build:css": "tailwindcss -i ./src/package.css -o ./dist/styles.css --minify",
		"dev:css": "tailwindcss -i ./src/package.css -o ./dist/styles.css --watch",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.38.0",
		"@iconify/json": "^2.2.398",
		"@sveltejs/kit": "^2.47.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/cli": "^4.1.15",
		"@tailwindcss/vite": "^4.1.15",
		"@types/node": "^22.18.12",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.5",
		"globals": "^16.4.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"publint": "^0.3.21",
		"@xyflow/svelte": "^1.5.2",
		"svelte": "^5.41.1",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.1.15",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.2",
		"unplugin-icons": "^22.5.0",
		"vite": "^7.1.11",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@dagrejs/dagre": "^1.1.5",
		"@zag-js/floating-panel": "^1.26.3",
		"@zag-js/svelte": "^1.26.3",
		"fuse.js": "^7.1.0",
		"mode-watcher": "^1.1.0",
		"nanoid": "^5.1.6",
		"svelte-5-french-toast": "^2.0.6"
	},
	"peerDependencies": {
		"@sveltejs/kit": ">=2.0.0",
		"@xyflow/svelte": ">=1.5.2",
		"svelte": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"svelte": {
			"optional": false
		},
		"@sveltejs/kit": {
			"optional": false
		}
	}
}
